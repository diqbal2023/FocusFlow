{
  "name": "FocusFlow",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "node scripts/patch-turbo-sqlite-windows.js",
    "windows": "set \"DOTNET_ROOT=C:\\Program Files\\dotnet\" && set \"PATH=C:\\Program Files\\dotnet;%PATH%\" && npx @react-native-community/cli run-windows",
    "package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows.ps1",
    "clean:windows": "npx react-native clean --include windows",
    "test:windows": "jest --config jest.config.windows.js"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.86.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-turbo-sqlite": "^0.6.2",
    "react-native-windows": "^0.84.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@rnx-kit/jest-preset": "^0.3.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "FocusFlow",
      "namespace": "FocusFlow",
      "template": "cpp-app"
    }
  }
}
